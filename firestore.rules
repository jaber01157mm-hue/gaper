rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt == request.time;
    }

    function isValidVehicle(data) {
      return data.keys().hasAll(['ownerId', 'make', 'model', 'licensePlate', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.ownerId == request.auth.uid &&
             data.make is string && data.make.size() <= 50 &&
             data.model is string && data.model.size() <= 50 &&
             data.licensePlate is string && data.licensePlate.size() <= 20 &&
             data.createdAt == request.time;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['userId', 'serviceType', 'date', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.serviceType in ['oil_change', 'mechanical', 'electrical', 'diagnostic', 'general'] &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'] &&
             data.date is string &&
             data.createdAt == request.time;
    }

    function isValidRecord(data) {
      return data.keys().hasAll(['vehicleId', 'serviceType', 'date', 'createdAt']) &&
             data.serviceType is string &&
             data.date is string &&
             data.createdAt == request.time;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'phoneNumber']);
    }

    match /vehicles/{vehicleId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidVehicle(incoming());
      allow update: if isSignedIn() && existing().ownerId == request.auth.uid && isValidVehicle(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['make', 'model', 'year', 'licensePlate', 'vin']);
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;

      match /history/{recordId} {
        allow list, get: if isSignedIn() && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerId == request.auth.uid;
        // Records are typically created by staff, but for this demo, we allow the owner to track their own history
        allow create: if isSignedIn() && get(/databases/$(database)/documents/vehicles/$(vehicleId)).data.ownerId == request.auth.uid && isValidRecord(incoming());
      }
    }

    match /bookings/{bookingId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidBooking(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && isValidBooking(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'time', 'notes', 'status']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending';
    }
  }
}
